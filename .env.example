# =============================================================================
# .env.example — template. Copy to ".env" and fill in real values.
# The real .env is excluded from commits via .gitignore.
# =============================================================================

# --- Data layer --------------------------------------------------------------
# Postgres format:  postgres://USER:PASSWORD@HOST:5432/DBNAME
# DATABASE_URL is the shared default. Each service reads its own
# <SERVICE>_DATABASE_URL and falls back to DATABASE_URL when it is unset, so the
# default single-database deployment only needs DATABASE_URL. Scaled deployments
# point each service at its own database/instance by setting the specific URL.
DATABASE_URL=postgres://USER:PASSWORD@DB_HOST:5432/DBNAME
# AUTH_DATABASE_URL=postgres://USER:PASSWORD@DB_HOST:5432/DBNAME
# INSTRUMENTS_DATABASE_URL=...
# PORTFOLIO_DATABASE_URL=...
# MARKET_DATABASE_URL=...
# FUNDAMENTALS_DATABASE_URL=...
# EVENTS_DATABASE_URL=...
# INSIGHTS_DATABASE_URL=...
# Valkey/Redis format (password only, no user): redis://:PASSWORD@HOST:6379
# Required by services that participate in the event bus (e.g. portfolio).
VALKEY_URL=redis://:PASSWORD@VALKEY_HOST:6379

# --- Service ports & runtime -------------------------------------------------
# The Next.js web UI is the user-facing app on http://localhost:3000 (its port
# is set in web/package.json, not here). The gateway (public API edge) is on
# 3001; backend services on 3002–3009; the providers egress service on 3010.
# Web UI: http://localhost:3000
GATEWAY_PORT=3001
AUTH_PORT=3002
PORTFOLIO_PORT=3003
INSTRUMENTS_PORT=3004
MARKET_PORT=3005
INSIGHTS_PORT=3006
FUNDAMENTALS_PORT=3007
EVENTS_PORT=3008
NOTIFICATIONS_PORT=3009
PROVIDERS_PORT=3010
NODE_ENV=development
SERVICE_VERSION=0.1.0

# Base URLs services use to reach each other over HTTP (gateway → upstreams,
# and service → service).
AUTH_BASE_URL=http://localhost:3002
PORTFOLIO_BASE_URL=http://localhost:3003
INSTRUMENTS_BASE_URL=http://localhost:3004
MARKET_BASE_URL=http://localhost:3005
INSIGHTS_BASE_URL=http://localhost:3006
FUNDAMENTALS_BASE_URL=http://localhost:3007
EVENTS_BASE_URL=http://localhost:3008
NOTIFICATIONS_BASE_URL=http://localhost:3009
# Providers service: the single egress to external market-data sources
# (Yahoo, ECB, …). Internal-only; not exposed through the gateway.
PROVIDERS_BASE_URL=http://localhost:3010

# --- Gateway edge ------------------------------------------------------------
# Comma-separated allowed CORS origins, or * to reflect any (dev only).
GATEWAY_CORS_ORIGINS=*
GATEWAY_RATE_LIMIT_MAX=300
GATEWAY_RATE_LIMIT_WINDOW_MS=60000

# --- Providers service: external data sources --------------------------------
# The providers service is the single egress to all external market-data
# sources. Yahoo Finance is an unofficial integration (via the yahoo-finance2
# library, which manages its own endpoints/crumb); verify terms at deployment
# time. ECB publishes the euro foreign-exchange reference rates.
ECB_DAILY_URL=https://www.ecb.europa.eu/stats/eurofxref/eurofxref-daily.xml
ECB_HIST_URL=https://www.ecb.europa.eu/stats/eurofxref/eurofxref-hist-90d.xml
# Lang & Schwarz TradeCenter (public chart API; no credential). Enabled per
# provider via its provider_settings row (seeded disabled, migration 021).
# LSTC_QUOTE_TYPE: 'mid' (bid/ask midpoint, default) or 'max' (last traded).
LSTC_BASE_URL=https://www.ls-tc.de
LSTC_TIMEOUT_MS=8000
LSTC_QUOTE_TYPE=mid

# --- Instruments service: watch-set authority --------------------------------
# Consume the portfolio stream into the canonical watch-interest projection and
# broadcast resolved watch deltas. INSTRUMENTS_WATCH_PROVIDER is the provider
# namespace whose symbol the watch set carries.
INSTRUMENTS_CONSUME_INTEREST_STREAM=true
INSTRUMENTS_WATCH_PROVIDER=yahoo

# --- Market service: refresh -------------------------------------------------
# The watched-listing set comes from the instruments watch-set snapshot + deltas
# (see INSTRUMENTS_* above); MARKET_REFRESH_ENABLED gates both hydrating it and
# the refresh cycle.
MARKET_REFRESH_ENABLED=true
# Heartbeat: how often the sweep wakes to evaluate per-(provider × capability)
# due-ness. Actual cadence per provider/capability is admin-configured in the DB
# (providers.provider_capability_refresh) and editable from Administration →
# Providers. MARKET_REFRESH_INTERVAL_MS is now only the fallback interval for a
# provider/capability with no configured cadence.
MARKET_REFRESH_TICK_MS=60000
MARKET_REFRESH_INTERVAL_MS=900000
# After an exchange closes, the sweep does ONE extra "catch the close" quote fetch
# within this window so the daily close is captured even though the venue is now
# closed (and the freshness interval may not have elapsed).
MARKET_CLOSE_CAPTURE_GRACE_MS=1800000

# --- Insights service --------------------------------------------------------
# Consume the market stream to ingest analyst assessments (Yahoo) as global
# fair values + price targets.
INSIGHTS_CONSUME_ANALYST_STREAM=true

# --- Fundamentals service ----------------------------------------------------
# Refreshes fundamentals in the background via the providers service over the
# instruments watch set (see INSTRUMENTS_* above). The freshness gate skips an
# instrument whose newest snapshot is younger than FUNDAMENTALS_MIN_AGE_MS.
# FUNDAMENTALS_REFRESH_TICK_MS is the heartbeat; per-provider cadence is admin-
# configured (providers.provider_capability_refresh). FUNDAMENTALS_MIN_AGE_MS is
# the fallback freshness threshold for a provider with no configured cadence.
FUNDAMENTALS_REFRESH_ENABLED=true
FUNDAMENTALS_REFRESH_TICK_MS=300000
FUNDAMENTALS_MIN_AGE_MS=72000000

# --- Events service ----------------------------------------------------------
# Refreshes earnings, corporate actions, and news in the background via the
# providers service over the instruments watch set (see INSTRUMENTS_* above). The
# per-instrument freshness gate skips instruments refreshed within EVENTS_MIN_AGE_MS.
# EVENTS_REFRESH_TICK_MS is the heartbeat; per-provider cadence is admin-configured
# (providers.provider_capability_refresh). EVENTS_MIN_AGE_MS is the fallback
# freshness threshold for a provider with no configured cadence.
EVENTS_REFRESH_ENABLED=true
EVENTS_REFRESH_TICK_MS=300000
EVENTS_MIN_AGE_MS=21600000

# --- Notifications service (v2) ----------------------------------------------
# Consumes the portfolio interest stream and evaluates §2.7 alerts on a schedule:
# significant daily move (>= NOTIFICATIONS_DAILY_MOVE_PCT %), upcoming earnings
# (within NOTIFICATIONS_EARNINGS_WITHIN_DAYS days), and price entering the user's
# own target zone.
NOTIFICATIONS_EVAL_ENABLED=true
NOTIFICATIONS_EVAL_INTERVAL_MS=900000
NOTIFICATIONS_DAILY_MOVE_PCT=5
NOTIFICATIONS_EARNINGS_WITHIN_DAYS=7
NOTIFICATIONS_CONSUME_INTEREST_STREAM=true
# React to market quote events immediately; periodic evaluation remains the fallback.
NOTIFICATIONS_CONSUME_MARKET_STREAM=true
# Delete read notifications after 7 days; unread notifications stay until read.
NOTIFICATIONS_READ_RETENTION_DAYS=7
NOTIFICATIONS_RETENTION_CLEANUP_INTERVAL_MS=86400000
# Re-release snoozed notifications once their snooze window expires.
NOTIFICATIONS_SNOOZE_RELEASE_INTERVAL_MS=60000

# Web Push (VAPID) for desktop notifications. Generate a keypair once with
# `npx web-push generate-vapid-keys` and paste it below. Desktop push is only
# active when BOTH keys are set; otherwise the subscription endpoints still work
# but nothing is sent. VAPID_SUBJECT must be a mailto: or https: URL.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# --- Internal access tokens (authentication service) -------------------------
# RS256 private key (PKCS#8 PEM) used to sign internal access tokens. If unset,
# an ephemeral key is generated at startup (development only — tokens do not
# survive a restart). Downstream services validate tokens via the JWKS.
# AUTH_JWT_PRIVATE_KEY=
AUTH_JWT_KEY_ID=auth-1
AUTH_JWT_ISSUER=http://localhost:3002
AUTH_JWT_AUDIENCE=portfolio-platform

# --- Bootstrap (first-start setup, see bootstrap.ts) -------------------------
BOOTSTRAP_AUTH_LOCAL=true
BOOTSTRAP_AUTH_OIDC=false
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_NAME=Admin
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_min_12_chars
# If OIDC (Authentik) should be enabled:
# BOOTSTRAP_AUTH_OIDC=true
# BOOTSTRAP_OIDC_ISSUER=https://authentik.example.com/application/o/portfolio/
# BOOTSTRAP_OIDC_CLIENT_ID=your-client-id

# Shared secret guarding the HTTP POST /auth/setup endpoint. Callers must send
# it in the "x-setup-secret" header. If unset, the endpoint is disabled (501)
# and you must bootstrap via the CLI instead. Use a long random value.
AUTH_SETUP_SECRET=CHANGE_ME_long_random_secret

# --- Paths (defaults match the repo structure) -------------------------------
MIGRATIONS_DIR=packages/database/migrations
SEEDS_DIR=packages/database/seeds/development
