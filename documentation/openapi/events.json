          {
            "schema": {
              "minLength": 1,
              "maxLength": 16000,
              "type": "string"
            },
            "in": "query",
            "name": "instrument_ids",
            "required": false
          },
          {
            "schema": {
              "type": "boolean"
            },
            "in": "query",
            "name": "is_upcoming",
            "required": false
          },
          {
            "schema": {
              "minLength": 10,
              "maxLength": 10,
              "type": "string"
            },
            "in": "query",
            "name": "date_from",
            "required": false
          },
          {
            "schema": {
              "minLength": 10,
              "maxLength": 10,
              "type": "string"
            },
            "in": "query",
            "name": "date_to",
            "required": false
          },
          {
            "schema": {
              "minimum": 1,
              "maximum": 500,
              "type": "integer"
