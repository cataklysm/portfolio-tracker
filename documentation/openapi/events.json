{
  "openapi": "3.1.0",
  "info": {
    "title": "events API",
    "description": "Internal HTTP API for the events service.",
    "version": "0.1.0"
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {}
  },
  "paths": {
    "/events/earnings": {
      "get": {
        "parameters": [
          {
            "schema": {
              "format": "uuid",
              "type": "string"
            },
            "in": "query",
            "name": "instrument_id",
            "required": false
