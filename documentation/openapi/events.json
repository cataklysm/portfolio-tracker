{
  "openapi": "3.1.0",
  "info": {
    "title": "events API",
    "description": "Internal HTTP API for the events service.",
    "version": "0.1.0"
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {}
  },
  "paths": {
    "/events/earnings": {
      "get": {
        "parameters": [
          {
            "schema": {
              "format": "uuid",
              "type": "string"
            },
            "in": "query",
            "name": "instrument_id",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "instrument_id",
                      "fiscal_year",
                      "fiscal_quarter",
                      "period_end_date",
                      "report_date",
                      "eps_estimate",
                      "eps_actual",
                      "revenue_estimate",
                      "revenue_actual",
                      "surprise_pct",
                      "provider",
                      "is_upcoming"
                    ],
                    "properties": {
                      "instrument_id": {
                        "type": "string"
                      },
                      "fiscal_year": {
                        "type": "number"
                      },
                      "fiscal_quarter": {
                        "anyOf": [
                          {
                            "type": "integer"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "period_end_date": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "report_date": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "eps_estimate": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "eps_actual": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "revenue_estimate": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "revenue_actual": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "surprise_pct": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "provider": {
                        "type": "string"
                      },
                      "is_upcoming": {
                        "type": "boolean"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/events/corporate-actions": {
      "get": {
        "parameters": [
          {
            "schema": {
              "format": "uuid",
              "type": "string"
            },
            "in": "query",
            "name": "instrument_id",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "stable_action_id",
                      "version",
                      "instrument_id",
                      "type",
                      "ex_date",
                      "ratio_numerator",
                      "ratio_denominator",
                      "dividend_amount",
                      "dividend_currency",
                      "provider"
                    ],
                    "properties": {
                      "stable_action_id": {
                        "type": "string"
                      },
                      "version": {
                        "type": "integer"
                      },
                      "instrument_id": {
                        "type": "string"
                      },
                      "type": {
                        "type": "string"
                      },
                      "ex_date": {
                        "type": "string"
                      },
                      "ratio_numerator": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "ratio_denominator": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "dividend_amount": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "dividend_currency": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "provider": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/events/news": {
      "get": {
        "parameters": [
          {
            "schema": {
              "format": "uuid",
              "type": "string"
            },
            "in": "query",
            "name": "instrument_id",
            "required": true
          },
          {
            "schema": {
              "minimum": 1,
              "maximum": 50,
              "type": "integer"
            },
            "in": "query",
            "name": "limit",
            "required": false
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "id",
                      "instrument_id",
                      "published_at",
                      "provider",
                      "headline",
                      "url",
                      "sentiment"
                    ],
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "instrument_id": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "published_at": {
                        "type": "string"
                      },
                      "provider": {
                        "type": "string"
                      },
                      "headline": {
                        "type": "string"
                      },
                      "url": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "sentiment": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/events/refresh": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "listing_ids"
                ],
                "properties": {
                  "listing_ids": {
                    "minItems": 1,
                    "maxItems": 100,
                    "type": "array",
                    "items": {
                      "format": "uuid",
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "refreshed"
                  ],
                  "properties": {
                    "refreshed": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/internal/earnings": {
      "get": {
        "parameters": [
          {
            "schema": {
              "minLength": 1,
              "maxLength": 4000,
              "type": "string"
            },
            "in": "query",
            "name": "instrument_ids",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "instrument_id",
                      "report_date"
                    ],
                    "properties": {
                      "instrument_id": {
                        "type": "string"
                      },
                      "report_date": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
