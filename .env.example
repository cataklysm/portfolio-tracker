# =============================================================================
# .env.example — template. Copy to ".env" and fill in real values.
# The real .env is excluded from commits via .gitignore.
# =============================================================================

# --- Data layer --------------------------------------------------------------
# Postgres format:  postgres://USER:PASSWORD@HOST:5432/DBNAME
# DATABASE_URL is the shared default. Each service reads its own
# <SERVICE>_DATABASE_URL and falls back to DATABASE_URL when it is unset, so the
# default single-database deployment only needs DATABASE_URL. Scaled deployments
# point each service at its own database/instance by setting the specific URL.
DATABASE_URL=postgres://USER:PASSWORD@DB_HOST:5432/DBNAME
# AUTH_DATABASE_URL=postgres://USER:PASSWORD@DB_HOST:5432/DBNAME
# INSTRUMENTS_DATABASE_URL=...
# PORTFOLIO_DATABASE_URL=...
# MARKET_DATABASE_URL=...
# FUNDAMENTALS_DATABASE_URL=...
# EVENTS_DATABASE_URL=...
# INSIGHTS_DATABASE_URL=...
# Valkey/Redis format (password only, no user): redis://:PASSWORD@HOST:6379
# Required by services that participate in the event bus (e.g. portfolio).
VALKEY_URL=redis://:PASSWORD@VALKEY_HOST:6379

# --- Service ports & runtime -------------------------------------------------
# The Next.js web UI is the user-facing app on http://localhost:3000 (its port
# is set in web/package.json, not here). The gateway (public API edge) is on
# 3001; backend services on 3002–3008 (3009 left free for growth); the providers
# egress service on 3010.
# Web UI: http://localhost:3000
GATEWAY_PORT=3001
AUTH_PORT=3002
PORTFOLIO_PORT=3003
INSTRUMENTS_PORT=3004
MARKET_PORT=3005
INSIGHTS_PORT=3006
FUNDAMENTALS_PORT=3007
EVENTS_PORT=3008
PROVIDERS_PORT=3010
NODE_ENV=development
SERVICE_VERSION=0.1.0

# Base URLs services use to reach each other over HTTP (gateway → upstreams,
# and service → service).
AUTH_BASE_URL=http://localhost:3002
PORTFOLIO_BASE_URL=http://localhost:3003
INSTRUMENTS_BASE_URL=http://localhost:3004
MARKET_BASE_URL=http://localhost:3005
INSIGHTS_BASE_URL=http://localhost:3006
FUNDAMENTALS_BASE_URL=http://localhost:3007
EVENTS_BASE_URL=http://localhost:3008
# Providers service: the single egress to external market-data sources
# (Yahoo, ECB, …). Internal-only; not exposed through the gateway.
PROVIDERS_BASE_URL=http://localhost:3010

# --- Gateway edge ------------------------------------------------------------
# Comma-separated allowed CORS origins, or * to reflect any (dev only).
GATEWAY_CORS_ORIGINS=*
GATEWAY_RATE_LIMIT_MAX=300
GATEWAY_RATE_LIMIT_WINDOW_MS=60000

# --- Providers service: external data sources --------------------------------
# The providers service is the single egress to all external market-data
# sources. Yahoo Finance is an unofficial integration (via the yahoo-finance2
# library, which manages its own endpoints/crumb); verify terms at deployment
# time. ECB publishes the euro foreign-exchange reference rates.
ECB_DAILY_URL=https://www.ecb.europa.eu/stats/eurofxref/eurofxref-daily.xml
ECB_HIST_URL=https://www.ecb.europa.eu/stats/eurofxref/eurofxref-hist-90d.xml

# --- Market service: refresh -------------------------------------------------
MARKET_REFRESH_ENABLED=true
MARKET_REFRESH_INTERVAL_MS=900000
MARKET_CONSUME_INTEREST_STREAM=true

# --- Insights service --------------------------------------------------------
# Consume the market stream to ingest analyst assessments (Yahoo) as global
# fair values + price targets.
INSIGHTS_CONSUME_ANALYST_STREAM=true

# --- Fundamentals service ----------------------------------------------------
# Consumes the portfolio interest stream and refreshes fundamentals in the
# background via the providers service. The freshness gate skips an instrument
# whose newest snapshot is younger than FUNDAMENTALS_MIN_AGE_MS.
FUNDAMENTALS_REFRESH_ENABLED=true
FUNDAMENTALS_REFRESH_INTERVAL_MS=3600000
FUNDAMENTALS_MIN_AGE_MS=72000000
FUNDAMENTALS_CONSUME_INTEREST_STREAM=true

# --- Events service ----------------------------------------------------------
# Consumes the portfolio interest stream and refreshes earnings, corporate
# actions, and news in the background via the providers service. The per-
# instrument freshness gate skips instruments refreshed within EVENTS_MIN_AGE_MS.
EVENTS_REFRESH_ENABLED=true
EVENTS_REFRESH_INTERVAL_MS=3600000
EVENTS_MIN_AGE_MS=21600000
EVENTS_CONSUME_INTEREST_STREAM=true

# --- Internal access tokens (authentication service) -------------------------
# RS256 private key (PKCS#8 PEM) used to sign internal access tokens. If unset,
# an ephemeral key is generated at startup (development only — tokens do not
# survive a restart). Downstream services validate tokens via the JWKS.
# AUTH_JWT_PRIVATE_KEY=
AUTH_JWT_KEY_ID=auth-1
AUTH_JWT_ISSUER=http://localhost:3002
AUTH_JWT_AUDIENCE=portfolio-platform

# --- Bootstrap (first-start setup, see bootstrap.ts) -------------------------
BOOTSTRAP_AUTH_LOCAL=true
BOOTSTRAP_AUTH_OIDC=false
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_NAME=Admin
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_min_12_chars
# If OIDC (Authentik) should be enabled:
# BOOTSTRAP_AUTH_OIDC=true
# BOOTSTRAP_OIDC_ISSUER=https://authentik.example.com/application/o/portfolio/
# BOOTSTRAP_OIDC_CLIENT_ID=your-client-id

# Shared secret guarding the HTTP POST /auth/setup endpoint. Callers must send
# it in the "x-setup-secret" header. If unset, the endpoint is disabled (501)
# and you must bootstrap via the CLI instead. Use a long random value.
AUTH_SETUP_SECRET=CHANGE_ME_long_random_secret

# --- Paths (defaults match the repo structure) -------------------------------
MIGRATIONS_DIR=packages/database/migrations
SEEDS_DIR=packages/database/seeds/development
